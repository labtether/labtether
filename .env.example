# LabTether local development defaults
POSTGRES_DB=labtether
POSTGRES_USER=labtether
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
DATABASE_URL=postgres://labtether:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@localhost:5432/labtether?sslmode=disable
LABTETHER_DB_STATEMENT_TIMEOUT=30s

# DB connection pool tuning (defaults shown; uncomment to override)
# LABTETHER_DB_MAX_CONNS=10
# LABTETHER_DB_MIN_CONNS=2
# LABTETHER_DB_MAX_CONN_LIFETIME_MIN=5
# LABTETHER_DB_MAX_CONN_IDLE_TIME_MIN=1

API_PORT=8080
AGENT_PORT=8090
AGENT_SOURCE=labtether-agent

LABTETHER_API_BASE_URL=http://localhost:8080
LABTETHER_AGENT_BASE_URL=http://localhost:8090
LABTETHER_HUB_HTTP_PUBLISH_IP=127.0.0.1
LABTETHER_HUB_HTTPS_PUBLISH_IP=0.0.0.0

# Runtime settings baseline (UI overrides take precedence at runtime)
LABTETHER_POLL_INTERVAL_SECONDS=5
LABTETHER_DEFAULT_TELEMETRY_WINDOW=1h
LABTETHER_DEFAULT_LOG_WINDOW=1h
LABTETHER_LOG_QUERY_LIMIT=120
LABTETHER_DEFAULT_ACTOR_ID=owner
LABTETHER_DEFAULT_ACTION_DRY_RUN=true
LABTETHER_DEFAULT_UPDATE_DRY_RUN=true
LABTETHER_AGENT_TOKEN_TTL_HOURS=720

# API auth tokens (required; use long random values)
LABTETHER_OWNER_TOKEN=REPLACE_WITH_LONG_RANDOM_OWNER_TOKEN
# Optional for non-browser clients talking to the web-console proxy.
LABTETHER_API_TOKEN=REPLACE_WITH_LONG_RANDOM_API_TOKEN

# Encryption key for credential storage (required in secure deployments).
# Must be base64 for exactly 32 random bytes.
LABTETHER_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# Environment should default to production for compose/deployment usage.
LABTETHER_ENV=production

# Admin user password (required for deterministic secure startup).
LABTETHER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Internal service settings
STRUCTURED_ENABLED=true
INTERACTIVE_ENABLED=true
CONNECTOR_ENABLED=true
QUEUE_MAX_DELIVERIES=5
JOB_POLL_INTERVAL=500ms
RETENTION_APPLY_INTERVAL=5m

# Runtime execution/network hardening
LABTETHER_EXEC_ALLOWLIST_MODE=true
LABTETHER_EXEC_ALLOWED_BINARIES=
LABTETHER_EXEC_BLOCKED_BINARIES=
LABTETHER_SHELL_COMMAND_ALLOWLIST_MODE=false
LABTETHER_SHELL_COMMAND_ALLOWLIST_PREFIXES=
LABTETHER_SHELL_COMMAND_BLOCKED_SUBSTRINGS=
LABTETHER_OUTBOUND_ALLOWLIST_MODE=true
LABTETHER_OUTBOUND_ALLOW_PRIVATE=true
LABTETHER_OUTBOUND_ALLOW_LOOPBACK=true
LABTETHER_OUTBOUND_ALLOWED_HOSTS=
LABTETHER_OUTBOUND_ALLOWED_SCHEMES=http,https,ws,wss
LABTETHER_LOG_SANITIZE_MAX_LEN=512

# Demo mode (for demo.labtether.com — do NOT enable on production instances).
# Requires both vars. Makes the instance read-only with auto-auth.
# LABTETHER_DEMO_MODE=true
# LABTETHER_DEMO_CONFIRM=yes-this-is-a-demo-instance

# Optional: override guacd image.
# Default is pinned to the 1.6.0 multi-arch index digest in compose.
# If your Docker runtime still pulls an emulated amd64 image on ARM, pin the ARM64 digest explicitly:
# GUACD_IMAGE=guacamole/guacd:1.6.0@sha256:769987c20e99f59578305505ffa23418c24da73d579364f097cdf01d9866e5e5
