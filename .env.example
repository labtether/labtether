# LabTether — Optional Environment Overrides
# Copy to .env to customize. Nothing here is required — docker compose up works without it.
# Full reference: https://docs.labtether.com/docs/reference/environment-variables

# ── Secrets (auto-generated on first boot if omitted) ────────
# POSTGRES_PASSWORD=              # default: labtether (dev compose) / auto-generated (deploy)
# LABTETHER_ADMIN_PASSWORD=       # default: browser-based setup at /setup
# LABTETHER_OWNER_TOKEN=          # default: random 64-char hex
# LABTETHER_API_TOKEN=            # default: same as owner token
# LABTETHER_ENCRYPTION_KEY=       # default: random 32-byte key. Manual: openssl rand -base64 32

# ── Database ─────────────────────────────────────────────────
# POSTGRES_DB=labtether
# POSTGRES_USER=labtether
# LABTETHER_DB_STATEMENT_TIMEOUT=30s
# LABTETHER_DB_MAX_CONNS=10
# LABTETHER_DB_MIN_CONNS=2
# LABTETHER_DB_MAX_CONN_LIFETIME_MIN=5
# LABTETHER_DB_MAX_CONN_IDLE_TIME_MIN=1

# ── Network / ports ──────────────────────────────────────────
# API_PORT=8080
# LABTETHER_BIND_ADDRESS=127.0.0.1 # direct non-production default; production/containers use 0.0.0.0
# Non-loopback binds reject known defaults and owner/API tokens shorter than 32 bytes.
# LABTETHER_HUB_HTTP_PUBLISH_IP=127.0.0.1
# LABTETHER_HUB_HTTPS_PUBLISH_IP=0.0.0.0
# LABTETHER_ENV=production
# LABTETHER_EXTERNAL_URL=            # canonical browser-facing console origin
# LABTETHER_CORS_ALLOWED_ORIGINS=    # exact comma-separated scheme://host:port origins
# LABTETHER_TRUST_PROXY_HOSTS=       # comma-separated reverse-proxy DNS/service names
# LABTETHER_TRUST_PROXY_CIDRS=       # comma-separated proxy source CIDRs; loopback is always trusted

# ── Polling and display (UI overrides take precedence) ───────
# LABTETHER_POLL_INTERVAL_SECONDS=5
# LABTETHER_DEFAULT_TELEMETRY_WINDOW=1h
# LABTETHER_DEFAULT_LOG_WINDOW=1h
# LABTETHER_LOG_QUERY_LIMIT=120
# LABTETHER_DEFAULT_ACTOR_ID=owner
# LABTETHER_DEFAULT_ACTION_DRY_RUN=true
# LABTETHER_DEFAULT_UPDATE_DRY_RUN=true
# LABTETHER_AGENT_TOKEN_TTL_HOURS=720

# ── Agent enrollment / WebSocket safety ─────────────────────
# LABTETHER_ENROLLMENT_TOKEN_MAX_USES=256      # hard maximum: 4096; omitted max_uses defaults to 1
# LABTETHER_MAX_ENROLLED_AGENTS=1024           # hard maximum: 65536; only decommission frees a slot
# LABTETHER_MAX_AGENT_CONNECTIONS=2048         # hard maximum: 65536
# LABTETHER_MAX_AGENT_CONNECTIONS_PER_SOURCE=256 # hard maximum: 4096
# LABTETHER_AGENT_WS_CREDENTIAL_LEASE=2s       # clamped to 250ms..5s
# LABTETHER_AGENT_WS_MESSAGES_PER_SECOND=256   # hard maximum: 8192
# LABTETHER_AGENT_WS_MESSAGE_BURST=512         # hard maximum: 16384
# LABTETHER_AGENT_WS_BYTES_PER_SECOND=16777216 # hard maximum: 268435456
# LABTETHER_AGENT_WS_BYTE_BURST=67108864        # hard maximum: 1073741824
# LABTETHER_ALLOW_LEGACY_SHARED_AGENT_AUTH=false # temporary migration-only owner-token agent auth

# ── Worker / queue ───────────────────────────────────────────
# STRUCTURED_ENABLED=true
# INTERACTIVE_ENABLED=true
# CONNECTOR_ENABLED=true
# QUEUE_MAX_DELIVERIES=5
# JOB_POLL_INTERVAL=500ms
# SCHEDULE_POLL_INTERVAL=15s
# RETENTION_APPLY_INTERVAL=5m

# ── Execution / network hardening ────────────────────────────
# LABTETHER_EXEC_ALLOWLIST_MODE=true
# LABTETHER_EXEC_ALLOWED_BINARIES=
# LABTETHER_EXEC_BLOCKED_BINARIES=
# LABTETHER_SHELL_COMMAND_ALLOWLIST_MODE=false
# LABTETHER_SHELL_COMMAND_ALLOWLIST_PREFIXES=
# LABTETHER_SHELL_COMMAND_BLOCKED_SUBSTRINGS=
# LABTETHER_OUTBOUND_ALLOWLIST_MODE=true
# LABTETHER_OUTBOUND_ALLOW_PRIVATE=true
# LABTETHER_OUTBOUND_ALLOW_LOOPBACK=false
# LABTETHER_OUTBOUND_ALLOW_LINK_LOCAL=false
# LABTETHER_OUTBOUND_ALLOWED_HOSTS=
# LABTETHER_OUTBOUND_ALLOWED_SCHEMES=http,https,ws,wss
# LABTETHER_LOG_SANITIZE_MAX_LEN=512

# ── Guacd (remote desktop gateway) ──────────────────────────
# GUACD_IMAGE=guacamole/guacd:1.6.0@sha256:...

# ── Demo mode (demo.labtether.com only) ─────────────────────
# LABTETHER_DEMO_MODE=true
# LABTETHER_DEMO_CONFIRM=yes-this-is-a-demo-instance
