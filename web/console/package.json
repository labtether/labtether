{
  "name": "labtether-console",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:types && npm run lint:ui",
    "tsc": "tsc",
    "lint:types": "npm run -s tsc -- --noEmit",
    "lint:ui": "eslint .",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:https": "env -u NO_COLOR PLAYWRIGHT_SELF_SIGNED_HTTPS=1 playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual:https": "env -u NO_COLOR PLAYWRIGHT_SELF_SIGNED_HTTPS=1 playwright test e2e/visual-regression.spec.ts",
    "postinstall": "sh scripts/patch-novnc.sh"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4",
    "vite": "^8.0.5"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@novnc/novnc": "^1.5.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@spice-project/spice-html5": "^0.2.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "cmdk": "^1.1.1",
    "guacamole-common-js": "^1.5.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
