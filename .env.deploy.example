# LabTether release image
# Pin to a specific version. Do not use :latest in production deploys.
LABTETHER_VERSION=vX.Y.Z
LABTETHER_IMAGE=ghcr.io/labtether/labtether:${LABTETHER_VERSION}

# Third-party images should also be pinned to an exact tested version or digest.
# Replace the Postgres tag below with the exact tested patch once release validation records it.
POSTGRES_IMAGE=postgres:18-alpine@sha256:9a8afca54e7861fd90fab5fdf4c42477a6b1cb7d293595148e674e0a3181de15
GUACD_IMAGE=guacamole/guacd:1.6.0@sha256:8974eaa9ba32f713daf311e7cc8cd7e4cdfba1edea39eed75524e78ef4b08f4f

# Optional database overrides for the split-postgres deploy path.
POSTGRES_DB=labtether
POSTGRES_USER=labtether
# Optional bootstrap overrides.
# Leave the password blank to use the website setup flow.
# Runtime DB/owner/API/encryption secrets are generated automatically on first boot.
LABTETHER_ADMIN_USERNAME=admin
LABTETHER_ADMIN_PASSWORD=

# Network defaults
LABTETHER_HTTP_BIND=127.0.0.1
# Keep HTTPS bound to localhost until setup is complete, then widen intentionally if needed.
LABTETHER_HTTPS_BIND=127.0.0.1
LABTETHER_CONSOLE_BIND=127.0.0.1
# The published console port is owned by a no-secret ingress sidecar while the
# credential-bearing console remains on an internal network.
LABTETHER_CONSOLE_INGRESS_MAX_CONNECTIONS=512
LABTETHER_TLS_MODE=auto
# Internal hub/console routing follows LABTETHER_TLS_MODE automatically. For
# an external certificate whose DNS identity differs from "labtether", set an
# HTTPS origin that matches the certificate and keep the TCP connect host on
# Docker DNS. Mount a private CA into the console before overriding its path.
# LABTETHER_INTERNAL_API_BASE_URL=https://hub.internal.example:8443
# LABTETHER_INTERNAL_CONNECT_HOST=labtether
# LABTETHER_INTERNAL_CA_FILE=/ca/ca.crt
# NEXT_PUBLIC_HUB_API_PORT=8443
# Canonical browser-facing console origin. Set this when using OIDC or when
# generated install/discovery URLs must traverse a reverse proxy.
LABTETHER_EXTERNAL_URL=
# Optional comma-separated exact network origins (scheme, host, and port).
# Leave blank for the secure same-origin default.
LABTETHER_CORS_ALLOWED_ORIGINS=
# Hub-side reverse proxies outside loopback must be explicitly trusted by
# DNS/service name or source CIDR. The bundled Compose console uses web-console.
LABTETHER_TRUST_PROXY_HOSTS=web-console
LABTETHER_TRUST_PROXY_CIDRS=
# Keep at 0 unless the console is behind a trusted proxy that overwrites
# X-Forwarded-For. Set this to the exact number of trusted proxy hops.
LABTETHER_TRUST_PROXY_HOPS=0

# Agent enrollment and live-socket ceilings. Defaults are safe for most
# homelabs; raise deliberately and never above the documented hard bounds.
LABTETHER_ENROLLMENT_TOKEN_MAX_USES=256
LABTETHER_MAX_ENROLLED_AGENTS=1024
LABTETHER_MAX_AGENT_CONNECTIONS=2048
LABTETHER_MAX_AGENT_CONNECTIONS_PER_SOURCE=256
LABTETHER_AGENT_WS_CREDENTIAL_LEASE=2s
LABTETHER_AGENT_WS_MESSAGES_PER_SECOND=256
LABTETHER_AGENT_WS_MESSAGE_BURST=512
LABTETHER_AGENT_WS_BYTES_PER_SECOND=16777216
LABTETHER_AGENT_WS_BYTE_BURST=67108864
# Leave false. Enable only while migrating a legacy agent that still presents
# the shared owner token, then disable it after per-agent enrollment succeeds.
LABTETHER_ALLOW_LEGACY_SHARED_AGENT_AUTH=false

# LabTether is a homelab control plane, so deployed connectors may reach
# private LAN addresses. Loopback and link-local remain denied to prevent
# container-local or cloud-metadata pivots. Narrow the allowed hosts further
# if desired.
LABTETHER_OUTBOUND_ALLOW_PRIVATE=true
LABTETHER_OUTBOUND_ALLOW_LOOPBACK=false
LABTETHER_OUTBOUND_ALLOW_LINK_LOCAL=false

# Optional remote-desktop profile wiring
GUACD_HOST=guacd
GUACD_PORT=4822
